{
  "$id": "https://github.com/get-h3/protocol/schemas/v1/session-response.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SessionResponse",
  "description": "Response from GET /v1/sessions/{session_id} — session metadata.",
  "type": "object",
  "required": ["session_id", "started_at", "last_active", "turn_count", "status"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of session creation."
    },
    "last_active": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last activity."
    },
    "turn_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of turns completed."
    },
    "status": {
      "type": "string",
      "enum": ["active", "completed", "expired", "cancelled"],
      "description": "Current session status."
    },
    "current_decision": {
      "type": "string",
      "description": "ID of the currently executing decision, if any."
    },
    "current_decision_type": {
      "type": "string",
      "enum": ["tool_call", "llm_call", "text", "wait", "delegate", "end"],
      "description": "Type of the current decision, if any."
    }
  }
}
