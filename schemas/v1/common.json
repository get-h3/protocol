{
  "$id": "https://github.com/get-h3/protocol/schemas/v1/common.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "H3 Common Types",
  "description": "Shared type definitions for the H3 protocol.",
  "type": "object",
  "definitions": {
    "Message": {
      "type": "object",
      "required": ["role", "content", "timestamp"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user"],
          "description": "Always 'user' for /v1/process messages."
        },
        "content": {
          "type": "string",
          "description": "Message text content."
        },
        "attachments": {
          "type": "array",
          "description": "Optional attachments (images, files).",
          "items": { "$ref": "#/definitions/Attachment" }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the message."
        }
      }
    },
    "Attachment": {
      "type": "object",
      "required": ["type", "url", "mime_type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["image", "file", "audio", "video"],
          "description": "Attachment type."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "File URL (may be file:// or https://)."
        },
        "mime_type": {
          "type": "string",
          "description": "MIME type (e.g., image/png)."
        }
      }
    },
    "Identity": {
      "type": "object",
      "required": ["platform", "chat_id", "user_name", "user_id"],
      "properties": {
        "platform": {
          "type": "string",
          "description": "Messaging platform name (e.g., 'telegram')."
        },
        "chat_id": {
          "type": "string",
          "description": "Platform-specific chat identifier."
        },
        "thread_id": {
          "type": "string",
          "description": "Platform-specific thread identifier, if applicable."
        },
        "user_name": {
          "type": "string",
          "description": "Display name of the user."
        },
        "user_id": {
          "type": "string",
          "description": "Platform-specific user identifier."
        }
      }
    },
    "HistoryEntry": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "assistant", "system"],
          "description": "Message role in the conversation."
        },
        "content": {
          "type": "string",
          "description": "Message content."
        }
      }
    },
    "Tool": {
      "type": "object",
      "required": ["name", "description", "parameters"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique tool name."
        },
        "description": {
          "type": "string",
          "description": "Human-readable tool description."
        },
        "parameters": {
          "type": "object",
          "description": "JSON Schema for the tool's parameters.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["type"]
          }
        }
      }
    },
    "Model": {
      "type": "object",
      "required": ["name", "provider", "context_window"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Model name (e.g., 'deepseek-v4-pro')."
        },
        "provider": {
          "type": "string",
          "description": "Provider bucket name."
        },
        "cost_per_1k_input": {
          "type": "number",
          "description": "Cost per 1,000 input tokens in USD."
        },
        "cost_per_1k_output": {
          "type": "number",
          "description": "Cost per 1,000 output tokens in USD."
        },
        "context_window": {
          "type": "integer",
          "description": "Maximum context window in tokens."
        },
        "supports_vision": {
          "type": "boolean",
          "description": "Whether the model supports image inputs."
        },
        "supports_tool_calling": {
          "type": "boolean",
          "description": "Whether the model supports function/tool calling."
        }
      }
    },
    "SessionState": {
      "type": "object",
      "required": ["turn_count", "total_tool_calls", "total_llm_calls", "cost_so_far", "started_at"],
      "properties": {
        "turn_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of turns completed in this session."
        },
        "total_tool_calls": {
          "type": "integer",
          "minimum": 0,
          "description": "Total tool calls made in this session."
        },
        "total_llm_calls": {
          "type": "integer",
          "minimum": 0,
          "description": "Total LLM calls made in this session."
        },
        "cost_so_far": {
          "type": "number",
          "minimum": 0,
          "description": "Accumulated cost in USD."
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of session start."
        }
      }
    },
    "Config": {
      "type": "object",
      "required": ["max_iterations", "timeout_seconds"],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum agent reasoning iterations."
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Session timeout in seconds."
        },
        "project_dir": {
          "type": "string",
          "description": "Project working directory path."
        },
        "max_tool_calls_per_turn": {
          "type": "integer",
          "minimum": 0,
          "description": "Max tool calls per reasoning turn."
        },
        "temperature": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 2.0,
          "description": "LLM temperature (0.0–2.0, default 0.7)."
        }
      }
    },
    "Context": {
      "type": "object",
      "required": ["history", "tools", "models", "config", "session_state"],
      "properties": {
        "history": {
          "type": "array",
          "description": "Last N messages in the conversation.",
          "items": { "$ref": "#/definitions/HistoryEntry" }
        },
        "tools": {
          "type": "array",
          "description": "Available Hermes tools with full JSON Schema params.",
          "items": { "$ref": "#/definitions/Tool" }
        },
        "models": {
          "type": "array",
          "description": "Available LLMs with pricing and capabilities.",
          "items": { "$ref": "#/definitions/Model" }
        },
        "memory": {
          "type": "string",
          "description": "DuckBrain memory relevant to this session."
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Loaded skill names."
        },
        "config": {
          "$ref": "#/definitions/Config"
        },
        "session_state": {
          "$ref": "#/definitions/SessionState"
        }
      }
    }
  }
}
